<?xml version="1.0" encoding="utf-8"?>
<AutoClickerConfig>
  <!-- Koordinate kjer iščemo sliko -->
  <SearchX>100</SearchX>
  <SearchY>100</SearchY>

  <!-- Velikost območja za iskanje -->
  <SearchWidth>150</SearchWidth>
  <SearchHeight>80</SearchHeight>

  <!-- Koordinate kamor kliknemo, če najdemo sliko -->
  <ClickX>500</ClickX>
  <ClickY>500</ClickY>

  <!-- Pot do slike, ki jo iščemo -->
  <TemplateImagePath>template.png</TemplateImagePath>

  <!-- Interval preverjanja v milisekundah (3000 = 3 sekunde) -->
  <CheckIntervalMs>3000</CheckIntervalMs>

  <!-- Tolerance za ujemanje slik (0-255, nižje = bolj natančno) -->
  <MatchTolerance>30</MatchTolerance>

  <!-- Debug mode - shrani screenshote za analizo (true/false) -->
  <DebugMode>false</DebugMode>
</AutoClickerConfig>
